rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function bootstrapAdminEmail() {
      // 최초 관리자 Firebase Auth 이메일로 바꿔 주세요.
      return request.auth.token.email in [
        "legnanatas@jbnu.ac.kr"
      ];
    }

    function isAdmin() {
      return signedIn() && (
        bootstrapAdminEmail() ||
        get(/databases/$(database)/documents/gaongil_users/$(request.auth.uid)).data.role == "admin"
      );
    }

    match /gaongil_site/config {
      // 공개 메뉴와 공지는 방문자에게 읽혀야 하므로 read는 공개합니다.
      allow read: if true;
      // 변경은 관리자만 가능합니다.
      allow create, update, delete: if isAdmin();
    }

    match /gaongil_users/{userId} {
      allow read: if isAdmin()
        || (signedIn() && request.auth.uid == userId)
        || (signedIn() && resource.data.email == request.auth.token.email);
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
