rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function bootstrapAdminEmail() {
      // 지정된 Google 로그인 관리자 이메일입니다.
      return request.auth.token.email in [
        "legnanatas@jbnu.ac.kr",
        "legnanatas@naver.com"
      ];
    }

    function isAdmin() {
      return signedIn()
        && request.auth.token.firebase.sign_in_provider == "google.com"
        && bootstrapAdminEmail();
    }

    match /gaongil_site/config {
      // 공개 메뉴와 공지는 방문자에게 읽혀야 하므로 read는 공개합니다.
      allow read: if true;
      // 변경은 관리자만 가능합니다.
      allow create, update, delete: if isAdmin();
    }

    match /gaongil_users/{userId} {
      // 비로그인 상태에서도 로그인 비밀번호 검증을 위해 단일 문서 조회(get)는 항상 허용합니다.
      allow get: if true;
      // 전체 목록 조회(list)는 관리자만 허용합니다.
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
